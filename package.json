{
  "name": "captionx",
  "version": "0.1.1",
  "description": "Python 없이 바로 실행되는 자막 전사 데스크톱 앱 (Whisper 전사 + wav2vec2 단어 레벨 강제정렬)",
  "main": "./out/main/index.js",
  "author": "stelbite",
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format --check .",
    "fix": "biome check --write .",
    "deadcode": "knip",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "biome check . && npm run typecheck && npm run deadcode && npm run test",
    "pack:win": "electron-vite build && electron-builder --win --publish never",
    "pack:mac": "electron-vite build && electron-builder --mac --publish never",
    "patch:whisper-rpath": "node scripts/patch-whisper-rpath.mjs",
    "pack:linux": "npm run patch:whisper-rpath && electron-vite build && electron-builder --linux --publish never",
    "build:win": "npm run typecheck && npm run pack:win"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@fontsource/comic-neue": "^5.2.7",
    "@fontsource/gaegu": "^5.2.8",
    "@kutalia/whisper-node-addon": "^1.1.0",
    "ffmpeg-static": "^5.2.0",
    "onnxruntime-node": "^1.20.1",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "knip": "^5.42.1",
    "lefthook": "^2.1.9",
    "pretendard": "^1.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.8"
  }
}
