{
  "name": "captionx",
  "version": "0.2.0",
  "description": "Python 없이 바로 실행되는 자막 전사 데스크톱 앱 (Whisper 전사 + wav2vec2 단어 레벨 강제정렬)",
  "type": "module",
  "scripts": {
    "dev": "tauri dev -- --features full",
    "dev:vulkan": "tauri dev -- --features full-vulkan",
    "dev:cuda": "tauri dev -- --features full-cuda",
    "setup:gpu": "powershell -ExecutionPolicy Bypass -File scripts/setup-gpu-sdk.ps1",
    "build": "tauri build",
    "build:win": "tauri build -- --features full",
    "build:win-vulkan": "tauri build -- --features full-vulkan",
    "build:win-cuda": "tauri build -- --features full-cuda",
    "build:mac": "tauri build -- --features full-metal",
    "build:linux": "tauri build -- --features full-vulkan",
    "vite:dev": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json --composite false && tsc --noEmit -p tsconfig.web.json --composite false",
    "lint": "biome lint .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --features full --no-default-features -- -D warnings",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "test": "vitest run",
    "test:rust": "cargo t --manifest-path src-tauri/Cargo.toml --features full --no-default-features -- --skip test_align_progress_callback_called_when_model_present",
    "check": "npm run lint && npm run lint:rust && npm run typecheck && npm run test && npm run test:rust"
  },
  "dependencies": {
    "@fontsource/comic-neue": "^5.2.7",
    "@fontsource/gaegu": "^5.2.8",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "pretendard": "^1.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6",
    "vitest": "^4.1.8"
  }
}
