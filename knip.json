{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main/index.ts",
    "src/preload/index.ts",
    "src/renderer/src/main.tsx",
    "electron.vite.config.ts"
  ],
  "project": ["src/**/*.{ts,tsx,css}", "shared/**/*.ts"],
  "ignore": ["**/*.d.ts"],
  "ignoreDependencies": [
    "pretendard",
    "@fontsource/comic-neue",
    "@fontsource/gaegu",
    "@biomejs/biome",
    "electron-builder",
    "lefthook"
  ],
  "ignoreBinaries": [
    "biome",
    "knip",
    "tsc",
    "vitest",
    "electron-vite",
    "electron-builder",
    "lefthook"
  ],
  "ignoreExportsUsedInFile": true
}
